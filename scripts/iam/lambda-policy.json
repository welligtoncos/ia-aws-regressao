{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": ["logs:CreateLogGroup", "logs:CreateLogStream", "logs:PutLogEvents"],
      "Resource": "arn:aws:logs:us-east-1:303238378103:*"
    },
    {
      "Effect": "Allow",
      "Action": ["s3:ListBucket", "s3:GetObject"],
      "Resource": [
        "arn:aws:s3:::saldo-previsto-data-prod",
        "arn:aws:s3:::saldo-previsto-data-prod/*"
      ]
    },
    {
      "Effect": "Allow",
      "Action": ["dynamodb:PutItem", "dynamodb:GetItem", "dynamodb:UpdateItem"],
      "Resource": "arn:aws:dynamodb:us-east-1:303238378103:table/saldo-previsto-results-prod"
    },
    {
      "Effect": "Allow",
      "Action": ["glue:GetJobRun", "glue:GetJobRuns"],
      "Resource": [
        "arn:aws:glue:us-east-1:303238378103:job/saldo-previsto-glue-job-prod",
        "arn:aws:glue:us-east-1:303238378103:catalog",
        "arn:aws:glue:us-east-1:303238378103:job/*"
      ]
    }
  ]
}
